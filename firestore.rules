rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: subscriptions
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - showId: integer (required) - TVMaze show ID
    //   - showData: map (required) - Full show object
    //   - createdAt: timestamp (required) - Creation time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "aneta.lukasiewicz@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSubscription(data) {
      return data.keys().hasAll(['userId', 'showId', 'showData', 'createdAt']) &&
             data.userId is string &&
             data.showId is int &&
             data.showData is map &&
             (data.createdAt is timestamp || data.createdAt == null); // serverTimestamp is allowed
    }

    match /subscriptions/{subscriptionId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      allow create: if isAdmin() || (isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidSubscription(request.resource.data));
                      
      allow update: if false; // Subscriptions are immutable, delete and recreate if needed
      
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
